{
  "name": "saas-boilerplate",
  "private": true,
  "scripts": {
    "dev": "dotenv -- turbo run dev",
    "dev:clean": "pnpm kill-ports && dotenv -- turbo run dev",
    "kill-ports": "lsof -ti:3000,4000 | xargs kill -9 2>/dev/null; echo 'Ports 3000 and 4000 cleared'",
    "build": "turbo run build",
    "start": "turbo run start",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest watch",
    "lint": "eslint apps packages --ext .ts,.tsx",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "pnpm --filter @project/db db:migrate",
    "db:migrate:deploy": "pnpm --filter @project/db db:migrate:deploy",
    "db:push": "pnpm --filter @project/db db:push",
    "db:studio": "pnpm --filter @project/db db:studio",
    "db:seed": "pnpm --filter @project/db db:seed",
    "db:generate": "pnpm --filter @project/db db:generate",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "dotenv-cli": "^7.4.0",
    "@eslint/js": "^9.17.0",
    "@testcontainers/postgresql": "^10.18.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.19.0",
    "prettier": "^3.4.0",
    "testcontainers": "^10.18.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
