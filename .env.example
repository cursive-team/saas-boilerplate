# ============================================
# Development Configuration
# ============================================
# These variables are only needed for local development.
# They configure Docker container names and ports to allow
# running multiple apps simultaneously.

# Used for Docker container names and database names
# Change this when running multiple boilerplate instances
APP_SLUG="boilerplate"

# Custom port if running multiple apps (default: 5432)
# Update DATABASE_URL if you change this
POSTGRES_PORT="5432"

# Custom ports for MinIO object storage (defaults: 9000, 9001)
# Update BUCKET_ENDPOINT if you change MINIO_PORT
MINIO_PORT="9000"
MINIO_CONSOLE_PORT="9001"

# ============================================
# Database
# ============================================
# PostgreSQL connection string.
#
# For local development with Docker Compose, use the default below.
# The database name should match APP_SLUG (e.g., boilerplate_dev).
#
# For production (Railway): This is auto-injected when you add a PostgreSQL service.
# Go to: https://railway.app → Your project → Add PostgreSQL → Variables tab
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boilerplate_dev"

# ============================================
# API Configuration
# ============================================
# URL where the Express API is accessible.
# Used by the frontend to make API calls and for OAuth redirects.
#
# For local development: http://localhost:4000
# For production: Your Railway API URL (e.g., https://api.yourapp.com)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# URL where the Next.js frontend is accessible.
# Used for CORS configuration and email links.
#
# For local development: http://localhost:3000
# For production: Your Vercel URL (e.g., https://yourapp.com)
FRONTEND_URL="http://localhost:3000"

# ============================================
# Blob Storage (S3-compatible)
# ============================================
# Object storage for file uploads (avatars, documents, etc.)
#
# For local development: Docker Compose runs MinIO automatically.
# Access the MinIO console at http://localhost:9001 (admin/minioadmin)
#
# For production (Railway):
# 1. Go to: https://railway.app → Your project → Add Volume/Object Storage
# 2. Or use AWS S3: https://console.aws.amazon.com/s3
# 3. Or use Cloudflare R2: https://dash.cloudflare.com → R2

BUCKET_ENDPOINT="http://localhost:9000"
BUCKET_ACCESS_KEY_ID="minioadmin"
BUCKET_SECRET_ACCESS_KEY="minioadmin"
BUCKET_NAME="app-storage"
BUCKET_REGION="us-east-1"

# Production example (uncomment and fill in):
# BUCKET_NAME="your-bucket-name"
# BUCKET_REGION="us-east-1"
# BUCKET_ENDPOINT="https://your-bucket-endpoint.com"
# BUCKET_ACCESS_KEY_ID="your-access-key"
# BUCKET_SECRET_ACCESS_KEY="your-secret-key"

# ============================================
# Authentication
# ============================================
# Secret key for signing session tokens. Must be kept secret in production.
#
# Generate a secure secret with:
#   openssl rand -base64 32
#
# For local development, any string works. For production, use a strong random value.
BETTER_AUTH_SECRET="your-secret-key-change-in-production"

# ============================================
# Google OAuth
# ============================================
# Enable "Sign in with Google" functionality.
#
# Setup instructions:
# 1. Go to: https://console.cloud.google.com/apis/credentials
# 2. Create a new project (or select existing)
# 3. Configure OAuth consent screen (External, add your domain)
# 4. Create OAuth 2.0 Client ID (Web application)
# 5. Add authorized redirect URIs:
#    - http://localhost:4000/api/auth/callback/google (development)
#    - https://api.yourapp.com/api/auth/callback/google (production)
# 6. Copy Client ID and Client Secret below
#
# Documentation: https://developers.google.com/identity/protocols/oauth2
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# Stripe Billing
# ============================================
# Payment processing for subscriptions.
#
# Setup instructions:
# 1. Create account at: https://stripe.com
# 2. Get API keys from: https://dashboard.stripe.com/apikeys
#    - Use test keys (sk_test_...) for development
#    - Use live keys (sk_live_...) for production
# 3. Create products and prices: https://dashboard.stripe.com/products
#    - Create a product for each plan (Starter, Pro, etc.)
#    - Copy price IDs to cursive.json
# 4. Set up webhooks: https://dashboard.stripe.com/webhooks
#    - Endpoint URL: https://api.yourapp.com/webhooks/stripe
#    - Events to listen for:
#      - customer.subscription.created
#      - customer.subscription.updated
#      - customer.subscription.deleted
#      - invoice.payment_succeeded
#      - invoice.payment_failed
# 5. For local development, use Stripe CLI:
#    - Install: https://stripe.com/docs/stripe-cli
#    - Run: stripe listen --forward-to localhost:4000/webhooks/stripe
#
# Documentation: https://stripe.com/docs/billing/subscriptions/overview
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ============================================
# Resend Email
# ============================================
# Transactional emails (verification, password reset, invitations).
#
# Setup instructions:
# 1. Create account at: https://resend.com
# 2. Get API key from: https://resend.com/api-keys
# 3. Verify your domain: https://resend.com/domains
#    - Add the DNS records Resend provides
#    - Use your verified domain in FROM_EMAIL
#
# Documentation: https://resend.com/docs
RESEND_API_KEY=""
FROM_EMAIL="noreply@example.com"

# ============================================
# PostHog Analytics
# ============================================
# Product analytics, event tracking, and session replay.
#
# Setup instructions:
# 1. Create account at: https://posthog.com
# 2. Create a new project
# 3. Get API key from: https://app.posthog.com/project/settings
#    - Look for "Project API Key"
# 4. Enable Session Replay in: https://app.posthog.com/replay
#
# Documentation: https://posthog.com/docs
#
# Server-side analytics (backend API)
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# Client-side analytics with session replay (frontend)
# Must have NEXT_PUBLIC_ prefix for client-side access
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ============================================
# Sentry Error Tracking
# ============================================
# Error monitoring and performance tracking.
#
# Setup instructions:
# 1. Create account at: https://sentry.io
# 2. Create TWO projects:
#    - One for frontend (Next.js)
#    - One for backend (Node/Express)
# 3. Get DSN from: Project Settings → Client Keys (DSN)
#
# For source map uploads (optional, improves error debugging):
# 4. Create auth token: https://sentry.io/settings/auth-tokens/
#    - Scopes needed: project:releases, org:read
# 5. Set SENTRY_ORG and SENTRY_PROJECT for CI uploads
#
# Documentation: https://docs.sentry.io

# Web DSN must have NEXT_PUBLIC_ prefix for client-side access
NEXT_PUBLIC_SENTRY_DSN_WEB=""
SENTRY_DSN_API=""

# Optional: For source map uploads in CI
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ============================================
# Environment
# ============================================
# Node environment. Use "development" locally, "production" in deployment.
NODE_ENV="development"

# ============================================
# Logging
# ============================================
# Log level controls what gets logged.
# Options: debug, info, warn, error
#
# Recommended:
# - development: debug (verbose, helps with debugging)
# - production: info (balanced)
LOG_LEVEL="debug"
