{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm turbo run build --filter=@project/api"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "pnpm db:migrate:deploy && pnpm --filter @project/api start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
